# Servidor Backend - Variables de Entorno

PORT=8080

# Cadena de conexión directa a PostgreSQL en Supabase
# Ej: postgresql://postgres.hxyqiogduegbdlzgdylc:mi-contraseña-segura@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/postgres?sslmode=require

# Clave secreta JWT de Supabase (Settings -> API -> JWT Secret)
# Requerido para validar tokens JWT emitidos por Supabase Auth
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Configuración de cliente Supabase (Requerido para Auth Proxy)
# Settings -> API -> Project URL
SUPABASE_URL=https://your-project-id.supabase.co
# Settings -> API -> Project API Keys (anon o service_role)
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Cloudflare Turnstile Secret Key (Para validación de Captcha en Login/Registro)
# Usar clave secreta correspondiente al site key de Turnstile
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
